# Free Claude Code Docker config example
# Copy this file to .env and fill local values before running docker compose.

NVIDIA_NIM_API_KEY=""

MODEL="nvidia_nim/moonshotai/kimi-k2.6"

ANTHROPIC_AUTH_TOKEN="freecc"

FCC_OPEN_BROWSER=false
FCC_ENV_FILE=/config/.env
FCC_ADMIN_ALLOW_DOCKER=true

HOST=0.0.0.0
PORT=8082

MESSAGING_PLATFORM="none"
VOICE_NOTE_ENABLED=false

ENABLE_WEB_SERVER_TOOLS=false
LOG_RAW_API_PAYLOADS=false
LOG_RAW_SSE_EVENTS=false
LOG_API_ERROR_TRACEBACKS=false
LOG_RAW_MESSAGING_CONTENT=false
LOG_RAW_CLI_DIAGNOSTICS=false
LOG_MESSAGING_ERROR_DETAILS=false
